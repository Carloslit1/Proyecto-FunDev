    end

    subgraph Admin ["👔 Administrador"]
        AdminUser["🔑 Admin\n(VPN / Bastion SSH)"]
    end

    subgraph Logs ["📊 AWS Observabilidad"]
        CW["📋 CloudWatch Logs\napp.log stream"]
